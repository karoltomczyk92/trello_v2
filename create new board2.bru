info:
  name: create new board2
  type: http
  seq: 2

http:
  method: POST
  url: https://api.trello.com/1/boards/?name={name}&key=APIKey&token=APIToken
  params:
    - name: name
      value: "{name}"
      type: query
    - name: key
      value: APIKey
      type: query
    - name: token
      value: APIToken
      type: query
  auth: inherit

settings:
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
